---
import Layout from "@/layouts/Layout.astro";
import HeroSection from "@/components/HeroSection.jsx";
import AboutSection from "@/components/AboutSection.astro";
import LinksSection from "@/components/LinksSection.astro";
import GamesSection from "@/components/GamesSection.astro";
import JoinSection from "@/components/JoinSection.astro";
import ScrollReveal from "@/components/ScrollReveal.jsx";
---

<Layout title="Home">
  <!-- Hero: full-viewport with GSAP logo scroll animation -->
  <HeroSection client:load />

  <!-- About: who we are -->
  <ScrollReveal client:load>
    <AboutSection />
  </ScrollReveal>

  <!-- Divider -->
  <div class="max-w-7xl mx-auto px-6">
    <div class="border-t border-border/40"></div>
  </div>

  <!-- Games -->
  <ScrollReveal client:load delay={0.05}>
    <GamesSection />
  </ScrollReveal>

  <!-- Divider -->
  <div class="max-w-7xl mx-auto px-6">
    <div class="border-t border-border/40"></div>
  </div>

  <!-- Links / Socials -->
  <ScrollReveal client:load delay={0.05}>
    <LinksSection />
  </ScrollReveal>

  <!-- Join CTA -->
  <ScrollReveal client:load>
    <JoinSection />
  </ScrollReveal>
</Layout>
