---
// JoinSection.astro — Call to action / join the club
---

<section id="join" class="py-24 px-6">
  <div class="max-w-3xl mx-auto text-center">
    <div
      class="relative rounded-2xl border border-border/60 p-12 overflow-hidden"
      style="background: var(--color-card)"
    >
      <!-- Background glow -->
      <div
        class="absolute inset-0 pointer-events-none"
        aria-hidden="true"
        style="background: radial-gradient(ellipse at center, var(--brand-glow) 0%, transparent 70%); opacity: 0.6;"
      />

      <div class="relative z-10">
        <p class="text-sm font-semibold tracking-widest uppercase mb-4" style="color: var(--brand)">
          Ready to Play?
        </p>
        <h2 class="text-4xl md:text-5xl font-black tracking-tight mb-6">
          Join <span class="brand-gradient-text">EAOSU</span> Today
        </h2>
        <p class="text-muted-foreground text-lg mb-10 max-w-xl mx-auto leading-relaxed">
          Membership is free and open to all OSU students. No tryout required to join the
          community — competitive team placements happen each semester.
        </p>
        <div class="flex flex-wrap gap-4 justify-center">
          <a
            href="https://discord.gg/your-invite"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-8 py-3 rounded-lg font-bold text-sm transition-all duration-200 glow-brand"
            style="background: var(--brand); color: var(--color-primary-foreground);"
          >
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
              <path d="M20.317 4.492c-1.53-.69-3.17-1.2-4.885-1.49a.075.075 0 0 0-.079.036c-.21.369-.444.85-.608 1.23a18.566 18.566 0 0 0-5.487 0 12.36 12.36 0 0 0-.617-1.23A.077.077 0 0 0 8.562 3c-1.714.29-3.354.8-4.885 1.491a.07.07 0 0 0-.032.027C.533 9.093-.32 13.555.099 17.961a.08.08 0 0 0 .031.055 20.03 20.03 0 0 0 5.993 2.98.078.078 0 0 0 .084-.026c.462-.62.874-1.275 1.226-1.963.021-.04.001-.088-.041-.104a13.201 13.201 0 0 1-1.872-.878.075.075 0 0 1-.008-.125c.126-.093.252-.19.372-.287a.075.075 0 0 1 .078-.01c3.927 1.764 8.18 1.764 12.061 0a.075.075 0 0 1 .079.009c.12.098.245.195.372.288a.075.075 0 0 1-.006.125c-.598.344-1.22.635-1.873.877a.075.075 0 0 0-.041.105c.36.687.772 1.341 1.225 1.962a.077.077 0 0 0 .084.028 19.963 19.963 0 0 0 6.002-2.981.076.076 0 0 0 .032-.054c.5-5.094-.838-9.52-3.549-13.442a.06.06 0 0 0-.031-.028z"/>
            </svg>
            Join Discord
          </a>
          <a
            href="/about"
            class="inline-flex items-center gap-2 px-8 py-3 rounded-lg font-bold text-sm border border-border hover:bg-secondary transition-all duration-200"
          >
            Learn More
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
