---
// LinksSection.astro — Community links and socials
const links = [
  {
    name: "Discord",
    description: "Our main hub. Join the server to find teammates, get event updates, and hang out in voice channels.",
    href: "https://discord.gg/your-invite",
    icon: "discord",
    cta: "Join Server",
    gradient: "from-indigo-500 to-violet-600",
  },
  {
    name: "Instagram",
    description: "Follow us for highlights, event announcements, team spotlights, and behind-the-scenes content.",
    href: "https://instagram.com/eaosu",
    icon: "instagram",
    cta: "Follow Us",
    gradient: "from-pink-500 to-orange-400",
  },
  {
    name: "Twitter / X",
    description: "Live tournament updates, match results, and quick announcements from the org.",
    href: "https://twitter.com/eaosu",
    icon: "twitter",
    cta: "Follow",
    gradient: "from-sky-500 to-blue-600",
  },
  {
    name: "Linktree",
    description: "All our links in one place — rosters, schedules, registration forms, and more.",
    href: "https://linktr.ee/eaosu",
    icon: "link",
    cta: "View All Links",
    gradient: "from-green-500 to-teal-500",
  },
];
---

<section id="links" class="py-24 px-6">
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-16">
      <p class="text-sm font-semibold tracking-widest uppercase mb-3" style="color: var(--brand)">
        Get Connected
      </p>
      <h2 class="text-4xl md:text-5xl font-black tracking-tight">
        Find Us <span class="brand-gradient-text">Everywhere</span>
      </h2>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {links.map(({ name, description, href, icon, cta, gradient }) => (
        <a
          href={href}
          target="_blank"
          rel="noopener noreferrer"
          class="group relative flex flex-col rounded-xl border border-border/60 p-6 transition-all duration-300 hover:-translate-y-1 hover:border-border overflow-hidden"
          style="background: var(--color-card)"
        >
          <!-- Gradient hover overlay -->
          <div
            class={`absolute inset-0 opacity-0 group-hover:opacity-10 transition-opacity duration-300 bg-gradient-to-br ${gradient}`}
          />

          <!-- Icon -->
          <div
            class={`mb-4 w-12 h-12 rounded-lg flex items-center justify-center bg-gradient-to-br ${gradient}`}
          >
            {icon === "discord" && (
              <svg class="w-6 h-6 text-white" viewBox="0 0 24 24" fill="currentColor">
                <path d="M20.317 4.492c-1.53-.69-3.17-1.2-4.885-1.49a.075.075 0 0 0-.079.036c-.21.369-.444.85-.608 1.23a18.566 18.566 0 0 0-5.487 0 12.36 12.36 0 0 0-.617-1.23A.077.077 0 0 0 8.562 3c-1.714.29-3.354.8-4.885 1.491a.07.07 0 0 0-.032.027C.533 9.093-.32 13.555.099 17.961a.08.08 0 0 0 .031.055 20.03 20.03 0 0 0 5.993 2.98.078.078 0 0 0 .084-.026c.462-.62.874-1.275 1.226-1.963.021-.04.001-.088-.041-.104a13.201 13.201 0 0 1-1.872-.878.075.075 0 0 1-.008-.125c.126-.093.252-.19.372-.287a.075.075 0 0 1 .078-.01c3.927 1.764 8.18 1.764 12.061 0a.075.075 0 0 1 .079.009c.12.098.245.195.372.288a.075.075 0 0 1-.006.125c-.598.344-1.22.635-1.873.877a.075.075 0 0 0-.041.105c.36.687.772 1.341 1.225 1.962a.077.077 0 0 0 .084.028 19.963 19.963 0 0 0 6.002-2.981.076.076 0 0 0 .032-.054c.5-5.094-.838-9.52-3.549-13.442a.06.06 0 0 0-.031-.028z"/>
              </svg>
            )}
            {icon === "instagram" && (
              <svg class="w-6 h-6 text-white" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/>
              </svg>
            )}
            {icon === "twitter" && (
              <svg class="w-6 h-6 text-white" viewBox="0 0 24 24" fill="currentColor">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
              </svg>
            )}
            {icon === "link" && (
              <svg class="w-6 h-6 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
                <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
              </svg>
            )}
          </div>

          <h3 class="font-bold text-lg mb-2">{name}</h3>
          <p class="text-muted-foreground text-sm leading-relaxed flex-1">{description}</p>
          <span
            class={`mt-4 text-sm font-semibold inline-flex items-center gap-1 bg-gradient-to-r ${gradient} bg-clip-text`}
            style="-webkit-background-clip: text; -webkit-text-fill-color: transparent;"
          >
            {cta}
            <svg class="w-4 h-4" style="color: var(--brand)" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </span>
        </a>
      ))}
    </div>
  </div>
</section>
