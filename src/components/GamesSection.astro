---
// GamesSection.astro — Games we compete in
const games = [
  {
    name: "Valorant",
    genre: "Tactical Shooter",
    level: "Collegiate",
    color: "from-red-500 to-orange-500",
    icon: "🎯",
  },
  {
    name: "Overwatch 2",
    genre: "Team Shooter",
    level: "Collegiate",
    color: "from-orange-400 to-amber-500",
    icon: "🛡️",
  },
  {
    name: "League of Legends",
    genre: "MOBA",
    level: "Collegiate",
    color: "from-blue-500 to-cyan-500",
    icon: "⚔️",
  },
  {
    name: "Rocket League",
    genre: "Sports",
    level: "Collegiate",
    color: "from-sky-400 to-indigo-500",
    icon: "🚀",
  },
  {
    name: "CS2",
    genre: "Tactical Shooter",
    level: "Casual / Competitive",
    color: "from-yellow-500 to-orange-600",
    icon: "💣",
  },
  {
    name: "Apex Legends",
    genre: "Battle Royale",
    level: "Casual",
    color: "from-rose-500 to-pink-600",
    icon: "🔫",
  },
];
---

<section id="games" class="py-24 px-6">
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-16">
      <p class="text-sm font-semibold tracking-widest uppercase mb-3" style="color: var(--brand)">
        What We Play
      </p>
      <h2 class="text-4xl md:text-5xl font-black tracking-tight">
        Our <span class="brand-gradient-text">Game Roster</span>
      </h2>
      <p class="mt-4 text-muted-foreground text-lg max-w-xl mx-auto">
        From competitive collegiate leagues to casual club nights — we've got your game.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {games.map(({ name, genre, level, color, icon }) => (
        <div
          class="group relative rounded-xl border border-border/60 p-6 transition-all duration-300 hover:-translate-y-1 overflow-hidden cursor-default"
          style="background: var(--color-card)"
        >
          <!-- Top gradient bar -->
          <div class={`absolute top-0 left-0 right-0 h-1 bg-gradient-to-r ${color}`} />

          <div class="flex items-start gap-4">
            <span class="text-4xl">{icon}</span>
            <div>
              <h3 class="font-bold text-xl mb-1">{name}</h3>
              <p class="text-muted-foreground text-sm">{genre}</p>
              <span
                class={`mt-2 inline-block text-xs font-semibold px-2 py-1 rounded-full bg-gradient-to-r ${color} text-white`}
              >
                {level}
              </span>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
